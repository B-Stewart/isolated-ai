{
  "name": "isolated-ai",
  // Use the cloud image if you don't need customizations
  "image": "braydens/agentic-base:latest",
  // or custom docker file in folder with "Dockerfile"
  // "build": {
  //   "dockerfile": "Dockerfile" 
  // },
  "remoteUser": "agent",
  "containerUser": "agent",
  // Mount the workspace at the same path it has on the host. This matters for
  // Docker-out-of-Docker: bind mounts in docker-compose.yml are resolved by the
  // *host* daemon, so a `./data:/data` mount needs `$PWD` inside the container
  // to be a path the host can actually see. Mounting at /workspace would make
  // the host daemon look for /workspace/data, which doesn't exist on the host.
  "workspaceFolder": "${localWorkspaceFolder}",
  "workspaceMount": "source=${localWorkspaceFolder},target=${localWorkspaceFolder},type=bind,consistency=cached",
  // Give each repo a unique Compose project name so containers/networks/volumes
  // from different repos using this pattern don't collide on the host daemon.
  "containerEnv": {
    "COMPOSE_PROJECT_NAME": "${localWorkspaceFolderBasename}"
  },
  // "forwardPorts": [3000],
  // "portsAttributes": {
  //   "3000": { "label": "web" }
  // },
  // Agent config and auth bind-mounted from the host so containerized and
  // native (host-side) Claude/OpenCode share one source of truth. Requires the
  // host paths to exist with the right ownership before first launch — see the
  // base image README for the one-time setup. Playwright browsers stay on a
  // named volume; they're bulky binaries, not user-edited config.
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/agent/.claude,type=bind",
    "source=${localEnv:HOME}/.claude.json,target=/home/agent/.claude.json,type=bind",
    "source=${localEnv:HOME}/.config/opencode,target=/home/agent/.config/opencode,type=bind",
    "source=${localEnv:HOME}/.local/share/opencode,target=/home/agent/.local/share/opencode,type=bind",
    "source=${localEnv:HOME}/.config/rtk,target=/home/agent/.config/rtk,type=bind",
    "source=${localEnv:HOME}/.local/share/rtk,target=/home/agent/.local/share/rtk,type=bind",
    "source=isolated-pw-browsers,target=/home/agent/.cache/ms-playwright,type=volume",
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  // Hardening profile.
  // for the rationale behind each flag.
  //
  // FIREWALL: this devcontainer ships with the egress firewall OFF. Enabling it requires
  // loosening the cap-drop policy because sudo (which the firewall script needs to call
  // iptables) is blocked by --cap-drop=ALL — three steps total:
  //   1. Comment out the "--cap-drop=ALL" line in runArgs.
  //   2. Uncomment the three "// FIREWALL:" lines in runArgs (targeted drops + NET_ADMIN).
  //   3. Uncomment the "// FIREWALL:" postStartCommand line further down.
  // The base image's README documents the corresponding standalone invocation.
  "runArgs": [
    "--label=com.docker.compose.project=agentic-isolated-ai",
    "--cap-drop=ALL",
    // FIREWALL: "--cap-drop=NET_RAW",
    // FIREWALL: "--cap-drop=SYS_PTRACE",
    // FIREWALL: "--cap-add=NET_ADMIN",
    "--security-opt=no-new-privileges:true",
    "--pids-limit=4096",
    "--tmpfs=/tmp:rw,nosuid,exec"
  ],
  "postCreateCommand": {
    // FIREWALL: "firewall": "sudo /usr/local/bin/init-firewall.sh",
    // Auto-install the Chromium revision pinned by the project's own Playwright
    // version, so day-to-day use never hits a "browser not found" prompt. Runs
    // only if package.json mentions playwright; idempotent — re-runs are no-ops
    // when the matching revision is already in the pw-browsers cache.
    //
    // FIREWALL caveat: registry.npmjs.org is in the default allowlist but the
    // Playwright browser CDN (cdn.playwright.dev) is not. With the firewall on,
    // either add `-e FIREWALL_EXTRA_HOSTS=cdn.playwright.dev` to runArgs or run
    // this step with the firewall off (e.g. install browsers once on a non-FW
    // attach, then enable FW). postCreateCommand keys run in parallel, so
    // ordering against the firewall key isn't guaranteed regardless.
    "playwright-browsers": "if [ -f package.json ] && grep -q '\"playwright\"' package.json; then npx --yes playwright install chromium; fi"
    // "deps": "npm install"
  },
  "customizations": {
    "vscode": {
      "extensions": []
    }
  }
}