{
  // Name for VS Code, shown in the bottom left of the window when the container is running
  "name": "isolated-ai",
  // Use the cloud image if you don't need customizations
  "image": "braydens/agentic-base:latest",
  // or custom docker file in folder with "Dockerfile"
  // "build": {
  //   "dockerfile": "Dockerfile" 
  // },
  "remoteUser": "agent",
  "containerUser": "agent",
  "workspaceFolder": "${localWorkspaceFolder}",
  "workspaceMount": "source=${localWorkspaceFolder},target=${localWorkspaceFolder},type=bind,consistency=cached",
  "containerEnv": {
    "COMPOSE_PROJECT_NAME": "${localWorkspaceFolderBasename}"
  },
  // "forwardPorts": [3000],
  // "portsAttributes": {
  //   "3000": { "label": "web" }
  // },
  "mounts": [
    "source=isolated-claude-auth,target=/home/agent/.claude,type=volume",
    "source=isolated-opencode-auth,target=/home/agent/.local/share/opencode,type=volume",
    "source=isolated-opencode-config,target=/home/agent/.config/opencode,type=volume",
    "source=isolated-pw-browsers,target=/home/agent/.cache/ms-playwright,type=volume",
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  "runArgs": [
    // Name shown in docker tagged on the container, useful for debugging and visibility
    "--label=com.docker.compose.project=agentic-isolated-ai",
    // Some optional hardening flags
    "--cap-drop=ALL",
    "--security-opt=no-new-privileges:true",
    "--pids-limit=4096",
    "--tmpfs=/tmp:rw,nosuid,exec"
  ],
  "postCreateCommand": {
    // "deps": "npm install"
  },
  "customizations": {
    "vscode": {
      "extensions": []
    }
  }
}